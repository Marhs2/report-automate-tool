{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeeklyReportGenerationResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "dateRange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startDate": {
          "type": "string",
          "description": "주간보고 시작일"
        },
        "endDate": {
          "type": "string",
          "description": "주간보고 종료일"
        }
      },
      "required": [
        "startDate",
        "endDate"
      ]
    },
    "weeklySummary": {
      "type": "string",
      "maxLength": 1000,
      "description": "전체 주간보고 핵심 요약. 주요 완료 사항, 주요 진행 사항, 미해결 이슈, 다음 주 계획을 한 문단으로 요약한다."
    },
    "projects": {
      "type": "array",
      "description": "프로젝트별 주간보고 내용",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "projectName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "프로젝트명"
          },
          "projectSummary": {
            "type": "string",
            "maxLength": 600,
            "description": "해당 프로젝트의 주간 핵심 요약"
          },
          "completedTasks": {
            "type": "array",
            "description": "이번 주 완료된 업무. 여러 날 반복된 동일 업무는 하나로 병합한다.",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "inProgressTasks": {
            "type": "array",
            "description": "이번 주 말 기준 아직 진행 중인 업무. 이후 완료된 업무는 제외한다.",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "resolvedIssues": {
            "type": "array",
            "description": "이번 주 중 해결된 이슈. 오류 수정 완료, 문제 해결, 해결됨 등이 확인된 항목",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "unresolvedIssues": {
            "type": "array",
            "description": "이번 주 말 기준 해결되지 않은 이슈. 미해결, 원인 확인 중, 계속 발생, 남아 있음 등이 포함된 항목",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "requests": {
            "type": "array",
            "description": "협조 요청, 확인 필요, 자료 요청, 검토 요청 등",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "nextWeekPlans": {
            "type": "array",
            "description": "다음 주 계획 또는 주간보고 이후 진행 예정 작업",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 180
            }
          },
          "contributors": {
            "type": "array",
            "description": "해당 프로젝트를 보고한 작성자 목록",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 50
            }
          }
        },
        "required": [
          "projectName",
          "projectSummary",
          "completedTasks",
          "inProgressTasks",
          "resolvedIssues",
          "unresolvedIssues",
          "requests",
          "nextWeekPlans",
          "contributors"
        ]
      }
    },
    "missingSubmissions": {
      "type": "array",
      "description": "미제출자 목록. 입력에 제공된 미제출 정보를 그대로 정리한다.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "date": {
            "type": "string"
          },
          "author": {
            "type": "string"
          }
        },
        "required": [
          "date",
          "author"
        ]
      }
    }
  },
  "required": [
    "dateRange",
    "weeklySummary",
    "projects",
    "missingSubmissions"
  ]
}